{
  "id": "terminal",
  "name": "Terminal",
  "description": "An embedded shell, one ttyd process per instance. Configure the shell, working directory, and font size.",
  "version": "1.0.0",
  "author": "built-in",
  "category": "productivity",
  "instance_mode": "multi",
  "default_size": { "w": 6, "h": 4 },
  "min_size": { "w": 3, "h": 2 },
  "max_size": { "w": 12, "h": 12 },
  "communication": "free_form",
  "event_sources": [],
  "host_services": [],
  "requires": { "commands": ["ttyd"] },
  "permissions": {
    "subprocess": true,
    "network": false
  }
}
